# Technical / machine-only bin — exclude from indexing and AI context
.technical/**
*.jsonl
3-Resources/Watcher-*.md
*.log

# Exceptions for technical files that Cursor must access
!.technical/
!.technical/prompt-queue.jsonl
!.technical/queue-continuation.jsonl
!.technical/prompt-queue-audit.jsonl
!.technical/queue-gate-state.json
!.technical/task-handoff-comms.jsonl
!.technical/Run-Telemetry/
!.technical/Run-Telemetry/**
!.technical/Validator/
!.technical/Validator/**
!.technical/Internal-Repair-Agent/
!.technical/Internal-Repair-Agent/**
!.technical/scripts/
!.technical/scripts/**
!3-Resources/Watcher-Result.md
!3-Resources/Watcher-Result-sandbox.md
!3-Resources/Watcher-Result-godot.md
!.technical/parallel/sandbox/prompt-queue.jsonl
!.technical/parallel/godot/prompt-queue.jsonl

# Root-level technical files (must stay at root; Syncthing/Cursor read them here)
.stignore